MYSQL_DATABASE=aerogo
MYSQL_USER=aerogo_app
MYSQL_PASSWORD=change_me_app_password
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_PORT=3306

# Use this from a future API server, not directly from Flutter.
DATABASE_URL=mysql://aerogo_app:change_me_app_password@localhost:3306/aerogo

API_PORT=8000
PUBLIC_BASE_URL=http://localhost:8000
EMAIL_VERIFICATION_SECRET=change_me_to_a_long_random_secret
EMAIL_TOKEN_MAX_AGE_SECONDS=86400
# How long a login session token stays valid, in seconds (default 30 days).
SESSION_MAX_AGE_SECONDS=2592000

# Leave SMTP_HOST empty for development. The API will print verification links.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
DEFAULT_FROM_EMAIL=AeroGo <noreply@aerogo.local>
